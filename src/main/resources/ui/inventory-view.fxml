<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Pos?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ferreteria.controllers.InventoryController"
            styleClass="inventory-view-root">

    <top>
        <VBox spacing="10">
            <children>
                <Label text="Inventario" styleClass="view-title"/>
                <FlowPane hgap="8" vgap="8" prefWrapLength="900" styleClass="inventory-toolbar">
                    <children>
                        <TextField fx:id="searchField" promptText="Buscar por código o nombre... (Enter)" prefWidth="240" onAction="#onSearch" styleClass="inventory-search-field"/>
                        <Button text="Buscar" onAction="#onSearch" styleClass="inventory-action-button" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <RadioButton fx:id="radioAll" text="Todos" selected="true" styleClass="inventory-filter-radio"/>
                        <RadioButton fx:id="radioLowStock" text="Solo bajo stock" styleClass="inventory-filter-radio"/>
                        <Button text="Ajustar stock" onAction="#onAdjustStock" styleClass="inventory-action-button" style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827;"/>
                    </children>
                </FlowPane>
            </children>
            <padding>
                <Insets top="0" right="0" bottom="12" left="0"/>
            </padding>
        </VBox>
    </top>

    <center>
        <VBox spacing="12">
            <Label text="Stock actual" styleClass="inventory-section-title"/>
            <VBox styleClass="inventory-table-panel" spacing="6">
                <children>
                    <TableView fx:id="stockTable" prefHeight="220.0" styleClass="products-table inventory-table inventory-stock-table">
                        <columns>
                            <TableColumn fx:id="colCode" text="Código" prefWidth="100.0"/>
                            <TableColumn fx:id="colName" text="Producto" prefWidth="200.0"/>
                            <TableColumn fx:id="colStock" text="Stock" prefWidth="70.0" styleClass="numeric-column"/>
                            <TableColumn fx:id="colMinStock" text="Stock mín." prefWidth="80.0" styleClass="numeric-column"/>
                            <TableColumn fx:id="colSupplier" text="Proveedor" prefWidth="140.0"/>
                        </columns>
                    </TableView>
                    <FlowPane hgap="8" vgap="4" alignment="CENTER">
                        <Button fx:id="btnPrev" text="← Anterior" onAction="#onPrevPage" styleClass="inventory-action-button" style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827;"/>
                        <Label fx:id="pageLabel" text="Página 1 de 1" style="-fx-font-size: 13px; -fx-padding: 4 8;"/>
                        <Button fx:id="btnNext" text="Siguiente →" onAction="#onNextPage" styleClass="inventory-action-button" style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827;"/>
                    </FlowPane>
                </children>
            </VBox>
            <Label text="Lista de reposición (productos con bajo stock y contacto del proveedor)" styleClass="inventory-section-title"/>
            <VBox styleClass="inventory-table-panel">
                <children>
                    <TableView fx:id="replenishmentTable" prefHeight="180.0" styleClass="products-table inventory-table inventory-replenishment-table">
                        <columns>
                            <TableColumn fx:id="repColCode" text="Código" prefWidth="90.0"/>
                            <TableColumn fx:id="repColName" text="Producto" prefWidth="160.0"/>
                            <TableColumn fx:id="repColStock" text="Stock" prefWidth="55.0" styleClass="numeric-column"/>
                            <TableColumn fx:id="repColMin" text="Mín." prefWidth="50.0" styleClass="numeric-column"/>
                            <TableColumn fx:id="repColSupplier" text="Proveedor" prefWidth="120.0"/>
                            <TableColumn fx:id="repColPhone" text="Teléfono" prefWidth="100.0"/>
                            <TableColumn fx:id="repColEmail" text="Email" prefWidth="140.0"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </VBox>
    </center>

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

</BorderPane>